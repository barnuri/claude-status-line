{
  "name": "claude-status-line",
  "version": "1.0.0",
  "description": "Claude Code status line — shows cwd, model, context%, tokens, and rate-limit stats",
  "bin": {
    "claude-status-line": "./src/index.ts"
  },
  "scripts": {
    "start": "bun run src/index.ts",
    "setup": "bun run src/index.ts --setup",
    "capture": "bun run scripts/update-all.ts",
    "update-all": "bun run scripts/update-all.ts"
  },
  "keywords": ["claude", "claude-code", "status-line"],
  "author": "barnuri",
  "license": "MIT",
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^26.0.0",
    "playwright": "^1.53.0",
    "typescript": "^6.0.3"
  }
}
